# Copy to `.env` and fill in to (re)generate narration MP3s with `npm run narrate`.
# The app itself never needs this — narration MP3s are committed build artifacts
# in public/audio/, and the client only ever loads those static files.

# Required: your ElevenLabs API key (https://elevenlabs.io -> Profile -> API Keys).
ELEVENLABS_API_KEY=

# Optional overrides (sensible defaults live in scripts/generate-narration.ts):
# ELEVENLABS_VOICE_ID=UgBBYS2sOqTuMpoF3BR0   # coach voice (captain-selected default)
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32      # mono, speech-friendly, small files
